# --- Email credentials ---
EMAIL_ADDRESS=your@mail.ru
EMAIL_PASSWORD=app_password_here

# --- Bot target ---
BOT_EMAIL=bot@mail.ru

# --- Client behavior ---
# How long to wait for reply (seconds)
REPLY_TIMEOUT_SECONDS=4000

# How often to check inbox (seconds)
POLL_INTERVAL_SECONDS=30

# Client request cooldown
REQUEST_MIN_INTERVAL_MINUTES=30