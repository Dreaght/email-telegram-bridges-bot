TOR_BRIDGES_BOT_USERNAME=GetBridgesBot

REQUEST_COMMAND=/webtunnel
RESPONSE_MATCH=webtunnel

MESSAGING_COOLDOWN_HOURS=6
RESPONSE_TIMEOUT_SECONDS=30
MAX_RESPONSE_MESSAGES=10

IMAP_HOST=imap.mail.ru
IMAP_PORT=993
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465

# Obfuscation layer used by both bot and client.
OBFUSCATION_LAYER=pgp
