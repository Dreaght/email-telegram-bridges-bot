# --- Telegram API ---
# https://my.telegram.org/apps
# integer
API_ID=12345678
API_HASH=your_api_hash_here


# --- Session ---
# Generate using: python generate_session.py
# WARNING: grants full access to your Telegram account
SESSION=
# Example (do NOT reuse):
# SESSION=your_generated_string_session_here


# --- Proxy (optional) ---
# Use if Telegram is blocked or for traffic obfuscation
# Format: socks5://username:password@host:port
PROXY=
# Common local setup:
# PROXY=socks5://127.0.0.1:1080
# With auth:
# PROXY=socks5://user:pass@127.0.0.1:1080


# --- MTProto proxy (optional) ---
# If both PROXY and MTPROXY are set, MTPROXY is used
# Format: mtproto://SECRET@HOST:PORT
# If no secret: use 00000000000000000000000000000000
MTPROXY=
# Example:
# MTPROXY=mtproto://00000000000000000000000000000000@1.1.1.1:443


# --- Email credentials ---
EMAIL_ADDRESS=your@mail.ru
EMAIL_PASSWORD=app_password_here


# --- Mail servers ---
IMAP_HOST=imap.mail.ru
IMAP_PORT=993

SMTP_HOST=smtp.mail.ru
SMTP_PORT=465


# --- Trusted clients ---
# Comma-separated list of allowed signing key fingerprints
TRUSTED_FINGERPRINTS=
# Obfuscation layer name (default: pgp)
OBFUSCATION_LAYER=pgp
# Example:
# TRUSTED_FINGERPRINTS=ABCD1234EF567890...,1234AAAA5678BBBB...
